@{
}
<div class="row g-4">

    <div class="col-md-3">
        <a asp-controller="Product" asp-action="Index" class="text-decoration-none">
            <div class="card dashboard-card text-center">
                <div class="card-body">
                    <i class="bi bi-box-seam text-primary"></i>
                    <h5>Products</h5>
                    <p>Manage inventory</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Order" asp-action="Index" class="text-decoration-none">
            <div class="card dashboard-card text-center">
                <div class="card-body">
                    <i class="bi bi-receipt text-success"></i>
                    <h5>Orders</h5>
                    <p>View all orders</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Order" asp-action="SalesReport" class="text-decoration-none">
            <div class="card dashboard-card text-center">
                <div class="card-body">
                    <i class="bi bi-graph-up text-warning"></i>
                    <h5>Sales Report</h5>
                    <p>View revenue</p>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3">
        <a asp-controller="Customer" asp-action="Index" class="text-decoration-none">
            <div class="card dashboard-card text-center">
                <div class="card-body">
                    <i class="bi bi-people text-info"></i>
                    <h5>Customers</h5>
                    <p>Manage customers</p>
                </div>
            </div>
        </a>
    </div>

</div>
