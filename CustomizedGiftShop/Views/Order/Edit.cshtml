@{
}
@model CustomizedGiftShop.Models.DTO.OrderEditDto

<h2>Edit Order</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="OrderId" />

    <div class="mb-3">
        <label>Status</label>
        <select asp-for="Status" class="form-select">
            <option value="Pending">Pending</option>
            <option value="Completed">Completed</option>
            <option value="Cancelled">Cancelled</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Order Type</label>
        <select asp-for="OrderType" class="form-select">
            <option value="Takeaway">Takeaway</option>
            <option value="Delivery">Delivery</option>
        </select>
    </div>

    <div id="addressDiv" class="mb-3">
        <label>Delivery Address</label>
        <textarea asp-for="DeliveryAddress" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-warning">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

<script>
    const orderTypeSelect = document.querySelector('[name="OrderType"]');
    const addressDiv = document.getElementById('addressDiv');

    function toggleAddress() {
        addressDiv.style.display =
            orderTypeSelect.value === "Delivery" ? "block" : "none";
    }

    orderTypeSelect.addEventListener('change', toggleAddress);
    toggleAddress();
</script>
