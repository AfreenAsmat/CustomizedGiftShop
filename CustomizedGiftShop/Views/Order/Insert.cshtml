@{
}
@model CustomizedGiftShop.Models.DTO.OrderInsertDto

<div class="container mt-4">

    <div class="mb-4">
        <h2 class="fw-bold">Add New Order</h2>
        <p class="text-muted">Create a new customer order</p>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            <form asp-action="Insert" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                <!-- Customer -->
                <div class="mb-3">
                    <label class="form-label">Customer</label>
                    <select asp-for="CustomerId"
                            asp-items="ViewBag.Customers"
                            class="form-select">
                        <option value="">-- Select Customer --</option>
                    </select>
                    <span asp-validation-for="CustomerId" class="text-danger"></span>
                </div>

                <!-- Product -->
                <div class="mb-3">
                    <label class="form-label">Product</label>
                    <select asp-for="Items[0].ProductId"
                            asp-items="ViewBag.Products"
                            class="form-select">
                        <option value="">-- Select Product --</option>
                    </select>
                    <span asp-validation-for="Items[0].ProductId" class="text-danger"></span>
                </div>

                <!-- Quantity -->
                <div class="mb-3">
                    <label class="form-label">Quantity</label>
                    <input asp-for="Items[0].Quantity"
                           type="number"
                           min="1"
                           class="form-control" />
                    <span asp-validation-for="Items[0].Quantity" class="text-danger"></span>
                </div>

                <!-- Order Type -->
                <div class="mb-3">
                    <label class="form-label">Order Type</label>
                    <select asp-for="OrderType"
                            class="form-select"
                            id="orderType">
                        <option value="">-- Select Order Type --</option>
                        <option value="Takeaway">Takeaway</option>
                        <option value="Delivery">Delivery</option>
                    </select>
                    <span asp-validation-for="OrderType" class="text-danger"></span>
                </div>

                <!-- Delivery Address -->
                <div class="mb-3" id="addressDiv" style="display:none;">
                    <label class="form-label">Delivery Address</label>
                    <textarea asp-for="DeliveryAddress"
                              class="form-control"
                              rows="3"></textarea>
                    <span asp-validation-for="DeliveryAddress" class="text-danger"></span>
                </div>

                <!-- Buttons -->
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-success">
                        Save Order
                    </button>
                </div>
            </form>

        </div>
    </div>

</div>


<script>
    const orderTypeSelect = document.getElementById("orderType");
    const addressDiv = document.getElementById("addressDiv");

    function toggleAddress() {
        addressDiv.style.display =
            orderTypeSelect.value === "Delivery" ? "block" : "none";
    }

    orderTypeSelect.addEventListener("change", toggleAddress);
    toggleAddress();
</script>


