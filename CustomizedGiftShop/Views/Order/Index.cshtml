@{
}
@model IEnumerable<CustomizedGiftShop.Models.Order>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Orders</h2>

        <a asp-controller="Order" asp-action="Insert" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Order
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th>#</th>
                        <th>Customer</th>
                        <th>Products</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th style="width:260px">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var order in Model)
                    {
                            <tr>
                                <td class="text-center">@order.OrderId</td>

                                <td>@order.Customer.Name</td>

                                <td>
                                @foreach (var item in order.OrderDetails)
                                {
                                            <div>
                                        @item.Product?.Name
                                                <span class="badge bg-secondary">x @item.Quantity</span>
                                            </div>
                                }
                                </td>

                                <td>@order.OrderDate.ToShortDateString()</td>

                                <td class="fw-bold text-success">
                                    Rs. @order.TotalPrice
                                </td>

                                <td>@order.OrderType</td>

                                <td class="text-center">
                                @if (order.Status == "Pending")
                                {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                }
                                else if (order.Status == "Completed")
                                {
                                            <span class="badge bg-success">Completed</span>
                                }
                                else
                                {
                                            <span class="badge bg-danger">Cancelled</span>
                                }
                                </td>

                                <td class="text-center">

                                    <!-- View Bill -->
                                    <a asp-action="Details"
                                       asp-route-id="@order.OrderId"
                                       class="btn btn-info btn-sm mb-1"
                                       title="View Invoice">
                                        <i class="bi bi-receipt"></i>
                                    </a>

                                    <!-- Edit -->
                                    <a asp-action="Edit"
                                       asp-route-id="@order.OrderId"
                                       class="btn btn-warning btn-sm mb-1"
                                       title="Edit Order">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <!-- Delete -->
                                    <a asp-action="Delete"
                                       asp-route-id="@order.OrderId"
                                       class="btn btn-danger btn-sm mb-1"
                                       title="Delete Order">
                                        <i class="bi bi-trash"></i>
                                    </a>

                                    <!-- Sales Report -->
                                    <a asp-action="SalesReport"
                                       asp-route-id="@order.OrderId"
                                       class="btn btn-secondary btn-sm mb-1"
                                       title="Sales Report">
                                        <i class="bi bi-graph-up"></i>
                                    </a>

                                    <!-- Status Buttons -->
                                @if (order.Status == "Pending")
                                {
                                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@order.OrderId" />
                                                <input type="hidden" name="status" value="Completed" />
                                                <button class="btn btn-success btn-sm mb-1" title="Complete">
                                                    <i class="bi bi-check-circle"></i>
                                                </button>
                                            </form>

                                            <form asp-action="UpdateStatus" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@order.OrderId" />
                                                <input type="hidden" name="status" value="Cancelled" />
                                                <button class="btn btn-danger btn-sm mb-1" title="Cancel">
                                                    <i class="bi bi-x-circle"></i>
                                                </button>
                                            </form>
                                }
                                </td>
                            </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>
</div>
