@model IEnumerable<CustomizedGiftShop.Models.Product>

    <div class="container pb-5">
<h2>Products</h2>

<a asp-controller="Product" asp-action="Insert" class="btn btn-success mb-3">Add New Product</a>

<div class="row row-cols-1 row-cols-md-3 g-4 mt-3 mb-6">
    @foreach (var product in Model)
    {
            <div class="col">
                <div class="card h-100 shadow-sm">
                    <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height:200px; object-fit:contain;">
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text">
                            Price: <strong>$@product.Price</strong><br />
                            Stock: <strong>@product.Stock</strong><br />
                            Category: <strong>@product.Category</strong><br />
                            Description: @product.Description
                        </p>
                    </div>
                    <div class="card-footer text-center">
                        <a asp-action="Edit" asp-route-id="@product.ProductId" class="btn btn-sm btn-primary me-2">Edit</a>
                        <a asp-action="Delete" asp-route-id="@product.ProductId" class="btn btn-sm btn-danger">Delete</a>
                    </div>
                </div>
            </div>
    }
</div>

</div>
