@{
}
@model CustomizedGiftShop.Models.Customer

<h2>Delete Customer</h2>

<p>Are you sure you want to delete this customer?</p>

<ul>
    <li><b>Name:</b>@Model.Name</li>
    <li><b>Email:</b>@Model.Email</li>
    <li><b>Phone:</b>@Model.Phone</li>
    <li><b>Address:</b>@Model.Address</li>
</ul>

<form method="post">

    <input type="hidden" asp-for="CustomerId"/>

    <button type="submit" class="btn btn-danger">Delete</button>
    <a href="/Customer/Index" class="btn btn-secondary">Cancel</a>
</form>